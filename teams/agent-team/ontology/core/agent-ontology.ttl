    rdfs:label "Challenge Available"@en, "挑战可接收"@zh ;
    rdfs:comment "EV-02；message_type=challenge_available"@zh .

:SubmissionRequested a owl:Class ;
    rdfs:subClassOf :Event ;
    rdfs:label "Submission Requested"@en, "提交已请求"@zh ;
    rdfs:comment "EV-03；message_type=submission_request；🔴 RED-002/004/005 关联"@zh .

:ReviewRequested a owl:Class ;
    rdfs:subClassOf :Event ;
    rdfs:label "Review Requested"@en, "评审已请求"@zh ;
    rdfs:comment "EV-04；message_type=review_request"@zh .

:ReviewCompleted a owl:Class ;
    rdfs:subClassOf :Event ;
    rdfs:label "Review Completed"@en, "评审完成"@zh ;
    rdfs:comment "EV-05；message_type=review_result"@zh .

:FeedbackDelivered a owl:Class ;
    rdfs:subClassOf :Event ;
    rdfs:label "Feedback Delivered"@en, "反馈已送达"@zh ;
    rdfs:comment "EV-06；message_type=feedback；🔴 RED-009/010 关联"@zh .

:StatusUpdated a owl:Class ;
    rdfs:subClassOf :Event ;
    rdfs:label "Status Updated"@en, "状态已更新"@zh ;
    rdfs:comment "EV-07；message_type=status_update"@zh .

:FinalAdjusted a owl:Class ;
    rdfs:subClassOf :Event ;
    rdfs:label "Final Adjusted"@en, "最终调整"@zh ;
    rdfs:comment "EV-08；message_type=final_adjustment"@zh .

:PeerReviewRequested a owl:Class ;
    rdfs:subClassOf :Event ;
    rdfs:label "Peer Review Requested"@en, "同伴评审请求"@zh ;
    rdfs:comment "EV-09；message_type=peer_review_request"@zh .

:AgentOnline a owl:Class ;
