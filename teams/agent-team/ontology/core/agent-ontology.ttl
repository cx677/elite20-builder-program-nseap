# ---------- 协议关系（13 个）----------
:hasManifest a owl:ObjectProperty ;
    rdfs:label "has manifest"@en, "有清单"@zh ;
    rdfs:domain :Agent ; rdfs:range :AgentManifest ;
    owl:FunctionalProperty ;
