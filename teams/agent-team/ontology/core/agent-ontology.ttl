# 3 个 PRD §8.2 关键字段
:adminIdentityMode a owl:DatatypeProperty ;
    rdfs:label "admin identity mode"@en, "管理员身份模式"@zh ;
    rdfs:domain :Submission ; rdfs:range xsd:string ;
    rdfs:comment "PRD §4.3：2 个枚举值 independent_admin / teacher_delegated"@zh .

:reviewMode a owl:DatatypeProperty ;
    rdfs:label "review mode"@en, "评审模式"@zh ;
    rdfs:domain :Submission ; rdfs:range xsd:string ;
    rdfs:comment "PRD §8.2：3 个枚举值 teacher_only / peer_only / teacher_and_peer"@zh .

:routingStatus a owl:DatatypeProperty ;
    rdfs:label "routing status"@en, "路由状态"@zh ;
    rdfs:domain :Submission ; rdfs:range xsd:string ;
    rdfs:comment "PRD §8.2：4 个枚举值 not_routed / routed_to_teacher / routed_to_peer / routed_to_both"@zh .

# ====================================================================
# Module 9: Class Restrictions（10 条架构红线形式化）
# ====================================================================

# 🔴 RED-001: Submission Task Agent 是唯一能写 Submission 的 Agent
# 用 owl:FunctionalProperty + owl:InverseFunctionalProperty 实现
:Submission rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :processedByAgentId ;
    owl:cardinality 1
] , [
    a owl:Restriction ;
    owl:onProperty :hasAuditTrace ;
    owl:minCardinality 1
] .

# 🔴 RED-002: Student Companion 不能有 submission 写权限
:StudentCompanion rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :hasPermission ;
    owl:allValuesFrom [ a owl:Class ;
        owl:intersectionOf ( :Permission
            [ a owl:Restriction ;
                owl:onProperty :permissionScope ;
                owl:complementOf [ a owl:Class ;
                    owl:oneOf ( "feishu.submissions.write" ) ] ] ) ] ] .

# 🔴 RED-003: Teacher Companion 不能有 student 私有记忆读权限
:TeacherCompanion rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :hasPermission ;
    owl:allValuesFrom [ a owl:Class ;
        owl:intersectionOf ( :Permission
            [ a owl:Restriction ;
                owl:onProperty :permissionScope ;
                owl:complementOf [ a owl:Class ;
                    owl:oneOf ( "feishu.student_memory.read"
                                "feishu.personal_ontology.read" ) ] ] ) ] ] .

# 🔴 RED-004: MemoryBinding.ownerId 必须等于 StudentCompanion.agentId
:StudentCompanion rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :bindsToMemory ;
    owl:allValuesFrom [ a owl:Class ;
        owl:intersectionOf ( :MemoryBinding
            [ a owl:Restriction ;
                owl:onProperty :ownerId ;
                owl:cardinality 1 ] ) ] ] .

# 🔴 RED-005: Challenge 状态必须是 active 才能被提交
:Challenge rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :hasStatus ;
    owl:cardinality 1
] .

# 🔴 RED-006: Agent 必须有 Inbox
:Agent rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :inbounds ;
    owl:cardinality 1
] .

# 🔴 RED-007: TrustedRelationship 必须存在
:TrustedRelationship rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :agentA ;
    owl:cardinality 1
] , [
    a owl:Restriction ;
    owl:onProperty :agentB ;
    owl:cardinality 1
] , [
    a owl:Restriction ;
    owl:onProperty :trustLevel ;
    owl:cardinality 1
] .

# 🔴 RED-008: Submission 必须有至少一个 AuditTrace
# (已在上面 Submission 限制中包含 hasAuditTrace minCardinality 1)

# 🔴 RED-009: AgentManifest 不能有推送通知能力
:AgentManifest rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :hasCapability ;
    owl:allValuesFrom [ a owl:Class ;
        owl:intersectionOf ( :Capability
            [ a owl:Restriction ;
                owl:onProperty :capabilityName ;
                owl:complementOf [ a owl:Class ;
                    owl:oneOf ( "notify_student" "notify_teacher"
                                "send_push" "send_email" "send_sms" ) ] ] ) ] ] .

# 🔴 RED-010: 人触达通道 channelType 必须是 feishu
:ChannelBinding rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :channelType ;
    owl:cardinality 1
] .

# ---------- Skill 属性必填约束 ----------
:Skill rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :skillId ; owl:cardinality 1 ] ,
    [ a owl:Restriction ;
        owl:onProperty :skillName ; owl:cardinality 1 ] ,
    [ a owl:Restriction ;
        owl:onProperty :linkedTaskAgent ; owl:cardinality 1 ] .

# ---------- Event 必填约束 ----------
:Event rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :eventId ; owl:cardinality 1 ] ,
    [ a owl:Restriction ;
        owl:onProperty :timestamp ; owl:cardinality 1 ] ,
    [ a owl:Restriction ;
        owl:onProperty :sourceAgent ; owl:cardinality 1 ] ,
    [ a owl:Restriction ;
        owl:onProperty :targetAgent ; owl:cardinality 1 ] .

# ====================================================================
# Module 10: 枚举定义（14 个）
# ====================================================================

# AgentType 枚举
:AgentType a owl:Class ;
    owl:equivalentClass [ a owl:Class ;
        owl:oneOf ( :student-companion :teacher-companion :submission-task :review-task :peer-review ) ] .

:student-companion :AgentType .
:teacher-companion :AgentType .
:submission-task :AgentType .
:review-task :AgentType .
:peer-review :AgentType .

# PresenceStatus 枚举
:PresenceStatus a owl:Class ;
    owl:equivalentClass [ a owl:Class ;
        owl:oneOf ( :online :busy :offline :do-not-disturb :paused ) ] .

:online :PresenceStatus .
:busy :PresenceStatus .
:offline :PresenceStatus .
:do-not-disturb :PresenceStatus .
:paused :PresenceStatus .

# ChannelType 枚举
:ChannelType a owl:Class ;
    owl:equivalentClass [ a owl:Class ;
        owl:oneOf ( :web :github :feishu ) ] .

:web :ChannelType .
:github :ChannelType .
:feishu :ChannelType .

# SubmissionStatus 11 态枚举
:SubmissionStatus a owl:Class ;
    owl:equivalentClass [ a owl:Class ;
        owl:oneOf ( :statusDraft :statusSubmitted :statusValidating :statusNeedsRevision :statusChecked :statusPendingReview :statusUnderReview :statusReviewed :statusPendingTeacherReview :statusAccepted :statusNeedsTeacherRevision ) ] .

:statusDraft :SubmissionStatus .
:statusSubmitted :SubmissionStatus .
:statusValidating :SubmissionStatus .
:statusNeedsRevision :SubmissionStatus .
:statusChecked :SubmissionStatus .
:statusPendingReview :SubmissionStatus .
:statusUnderReview :SubmissionStatus .
:statusReviewed :SubmissionStatus .
:statusPendingTeacherReview :SubmissionStatus .
:statusAccepted :SubmissionStatus .
:statusNeedsTeacherRevision :SubmissionStatus .

