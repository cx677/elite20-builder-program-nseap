:agentType a owl:DatatypeProperty ;
    rdfs:label "agent type"@en, "智能体类型"@zh ;
    rdfs:domain :Agent ; rdfs:range xsd:string ;
    rdfs:comment "5 个枚举值：student-companion / teacher-companion / submission-task / review-task / peer-review"@zh .

:displayName a owl:DatatypeProperty ;
    rdfs:label "display name"@en, "显示名"@zh ;
    rdfs:domain :Agent ; rdfs:range xsd:string .

:status a owl:DatatypeProperty ;
    rdfs:label "status"@en, "状态"@zh ;
    rdfs:domain :Agent ; rdfs:range xsd:string ;
    rdfs:comment "5 个枚举值：online / busy / offline / do-not-disturb / paused"@zh .

