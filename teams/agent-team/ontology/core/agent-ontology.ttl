    rdfs:domain :Agent ; rdfs:range :Capability ;
    rdfs:comment "1:N；Agent 可拥有多个能力"@zh .

:exposesInterface a owl:ObjectProperty ;
    rdfs:label "exposes interface"@en, "暴露接口"@zh ;
    rdfs:domain :Agent ; rdfs:range :Interface .

:hasPermission a owl:ObjectProperty ;
    rdfs:label "has permission"@en, "有权限"@zh ;
    rdfs:domain :Agent ; rdfs:range :Permission ;
    rdfs:comment "1:N；🔴 RED-002/003 关联：StudentCompanion 不能有 submission.write；TeacherCompanion 不能有 student_memory.read"@zh .

:hasConstraint a owl:ObjectProperty ;
    rdfs:label "has constraint"@en, "有约束"@zh ;
    rdfs:domain :Agent ; rdfs:range :Constraint .

:trusts a owl:ObjectProperty ;
    rdfs:label "trusts"@en, "信任"@zh ;
    rdfs:domain :Agent ; rdfs:range :Agent ;
    rdfs:comment "N:N；🔴 RED-007：消息发送前必查 TrustedRelationship"@zh .

:bindsToMemory a owl:ObjectProperty ;
    rdfs:label "binds to memory"@en, "绑定记忆"@zh ;
    rdfs:domain :Agent ; rdfs:range :MemoryBinding ;
    rdfs:comment "1:N；🔴 RED-004：MemoryBinding.ownerId 必须 = StudentCompanion.agentId"@zh .

:bindsToChannel a owl:ObjectProperty ;
    rdfs:label "binds to channel"@en, "绑定通道"@zh ;
    rdfs:domain :Agent ; rdfs:range :ChannelBinding ;
    rdfs:comment "1:N；🔴 RED-010：人触达通道 channelType 必须是 feishu"@zh .

:inbounds a owl:ObjectProperty ;
    rdfs:label "inbounds"@en, "有收件箱"@zh ;
    rdfs:domain :Agent ; rdfs:range :AgentInbox ;
    owl:FunctionalProperty ;
